AdditionalGENIEReWeight_Tool_Config: {

    tool_type: "GENIEReWeight"

    # Updated 25 July 2023 by S. Gardiner
    # 23 Feb 2024: Copied from ICARUS_v2
    instance_name: "SBNNuSyst_GENIE_multisigma"

    # Keep one GENIEReWeight instance per discrete dial tweak in memory
    # Requires no reconfigures within the event loop
    UseFullHERG: true

    ignore_parameter_dependence: false

    ## 2p2h

    FracPN_CCMEC_central_value: 0
    FracPN_CCMEC_variation_descriptor: "[-1,+1,-2,+2,-3,+3]"

    FracDelta_CCMEC_central_value: 0
    FracDelta_CCMEC_variation_descriptor: "[-1,+1,-2,+2,-3,+3]"

    DecayAngMEC_central_value: 0
    DecayAngMEC_nthrows: 2
    DecayAngMEC_random_distribution: "gaussian"
    DecayAngMEC_variation_descriptor: "{-1,1}"

    DecayAng2MEC_central_value: 0
    DecayAng2MEC_nthrows: 2
    DecayAng2MEC_random_distribution: "gaussian"
    DecayAng2MEC_variation_descriptor: "{-1,1}"

    XSecShape_CCMEC_central_value: 0
    XSecShape_CCMEC_variation_descriptor: "[0, 1]"

    XSecShape_CCMEC_Empirical_central_value: 0
    XSecShape_CCMEC_Empirical_variation_descriptor: "[0, 1]"

    XSecShape_CCMEC_Martini_central_value: 0
    XSecShape_CCMEC_Martini_variation_descriptor: "[0, 1]"

    EnergyDependence_CCMEC_central_value: 0
    EnergyDependence_CCMEC_variation_descriptor: "[0, 1]"

}

syst_providers: [
AdditionalGENIEReWeight_Tool_Config
]
